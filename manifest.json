{
  "manifest_version": 3,
  "name": "AP Classroom Answer Hider",
  "version": "1.0",
  "description": "Hides answers, incorrect/correct indicators, and distractors in AP Classroom.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://*.collegeboard.org/*",
    "*://myap.collegeboard.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Toggle Answers"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.collegeboard.org/*",
        "*://myap.collegeboard.org/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ap-hider@jerry.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}